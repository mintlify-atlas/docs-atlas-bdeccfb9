  "keyFeatures": [
    "Gooey SVG blob animation with expandable details",
    "Five toast types with unique entrance animations",
    "Progress toasts with real-time updates",
    "Undo toasts with countdown timer",
    "Action buttons with icons and confirmation",
    "Promise-based API for async operations",
    "PHP facade and fluent builder API",
    "Livewire event integration",
    "User avatars and custom colors",
    "Dark/light theme support",
    "Mobile vibration API",
    "Persistent toasts",
    "Zero external CSS dependencies"
  ],
